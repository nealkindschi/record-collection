---
import BaseLayout from "../layouts/BaseLayout.astro";
import CollectionApp from "../components/CollectionApp";
import SearchBar from "../components/SearchBar";
import { searchReleases } from "../utils/db";

const db = Astro.locals.runtime.env.DB;
const { results: initialResults, total: initialTotal } = await searchReleases(db, { limit: 25, offset: 0 });
---

<BaseLayout title="Record Collection">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    <header class="mb-8 sm:mb-10 flex items-start justify-between gap-6">
      <div>
        <h1 class="font-display text-4xl sm:text-5xl tracking-wide text-white leading-none">Whichwax</h1>
        <p class="text-wax-400 text-sm mt-0.5 font-body">Search and browse your collection</p>
      </div>
      <div class="w-full max-w-sm sm:max-w-md lg:max-w-lg shrink-0">
        <SearchBar client:load query="" />
      </div>
    </header>
    <CollectionApp client:load initialResults={initialResults} initialTotal={initialTotal} />
  </div>
</BaseLayout>
